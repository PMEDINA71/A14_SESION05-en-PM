{
  "name": "Python 3.11",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "postCreateCommand": "python --version && pip install --upgrade pip && pip install numpy",

  "remoteUser": "vscode"
}
